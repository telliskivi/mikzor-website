---
// Vanilla-JS lightbox island. Wires up any <a data-lightbox href="..."> on the
// page to open a <dialog>-based overlay. Multiple links sharing the same
// data-gallery="<id>" become a navigable gallery (arrow keys, looping).
// Loaded with client:idle so it never blocks initial paint.
---

<dialog
  class="lightbox"
  data-lightbox-dialog
  aria-label="image viewer"
>
  <button
    class="close"
    type="button"
    data-lightbox-close
    aria-label="close"
  >×</button>
  <button
    class="nav prev"
    type="button"
    data-lightbox-prev
    aria-label="previous image"
    hidden
  >‹</button>
  <button
    class="nav next"
    type="button"
    data-lightbox-next
    aria-label="next image"
    hidden
  >›</button>
  <figure>
    <img data-lightbox-img alt="" />
    <figcaption data-lightbox-caption></figcaption>
  </figure>
</dialog>

<script>
  type Trigger = HTMLAnchorElement;

  const dialog = document.querySelector<HTMLDialogElement>('[data-lightbox-dialog]');
  if (dialog && typeof dialog.showModal === 'function') {
    const img = dialog.querySelector<HTMLImageElement>('[data-lightbox-img]')!;
    const caption = dialog.querySelector<HTMLElement>('[data-lightbox-caption]')!;
    const prevBtn = dialog.querySelector<HTMLButtonElement>('[data-lightbox-prev]')!;
    const nextBtn = dialog.querySelector<HTMLButtonElement>('[data-lightbox-next]')!;
    const closeBtn = dialog.querySelector<HTMLButtonElement>('[data-lightbox-close]')!;

    let currentGroup: Trigger[] = [];
    let currentIndex = 0;

    function show(index: number) {
      const trigger = currentGroup[index];
      if (!trigger) return;
      currentIndex = index;
      img.src = trigger.href;
      const altSrc = trigger.dataset.alt
        ?? trigger.querySelector('img')?.alt
        ?? '';
      img.alt = altSrc;
      caption.textContent = altSrc;
      const showNav = currentGroup.length > 1;
      prevBtn.hidden = !showNav;
      nextBtn.hidden = !showNav;
    }

    function open(trigger: Trigger) {
      const gallery = trigger.dataset.gallery;
      currentGroup = gallery
        ? Array.from(
            document.querySelectorAll<Trigger>(
              `a[data-lightbox][data-gallery="${gallery}"]`,
            ),
          )
        : [trigger];
      const startIdx = Math.max(0, currentGroup.indexOf(trigger));
      show(startIdx);
      dialog.showModal();
    }

    function step(delta: number) {
      if (currentGroup.length < 2) return;
      const next = (currentIndex + delta + currentGroup.length) % currentGroup.length;
      show(next);
    }

    document.addEventListener('click', (event) => {
      const target = event.target as Element | null;
      const trigger = target?.closest<Trigger>('a[data-lightbox]');
      if (!trigger) return;
      event.preventDefault();
      open(trigger);
    });

    prevBtn.addEventListener('click', () => step(-1));
    nextBtn.addEventListener('click', () => step(1));
    closeBtn.addEventListener('click', () => dialog.close());

    // backdrop click closes (clicks land on <dialog> itself, not its children)
    dialog.addEventListener('click', (event) => {
      if (event.target === dialog) dialog.close();
    });

    document.addEventListener('keydown', (event) => {
      if (!dialog.open) return;
      if (event.key === 'ArrowRight') {
        event.preventDefault();
        step(1);
      } else if (event.key === 'ArrowLeft') {
        event.preventDefault();
        step(-1);
      }
      // Escape is handled natively by <dialog>
    });
  }
</script>

<style>
  .lightbox {
    border: 0;
    padding: 0;
    background: transparent;
    color: var(--bg);
    max-width: 100vw;
    max-height: 100dvh;
    width: 100vw;
    height: 100dvh;
    margin: 0;
  }
  .lightbox::backdrop {
    background: rgba(0, 0, 0, 0.92);
    backdrop-filter: blur(2px);
  }
  .lightbox figure {
    display: grid;
    grid-template-rows: 1fr auto;
    place-items: center;
    width: 100%;
    height: 100%;
    margin: 0;
    padding: var(--sp-5);
    gap: var(--sp-3);
    box-sizing: border-box;
  }
  .lightbox img {
    max-width: 100%;
    max-height: 100%;
    object-fit: contain;
  }
  .lightbox figcaption {
    color: #cfcdc6;
    font-size: var(--fs-sm);
    text-align: center;
    min-height: 1.5em;
  }
  .lightbox button {
    position: fixed;
    background: transparent;
    color: #fff;
    border: 0;
    cursor: pointer;
    padding: 0.5rem 0.8rem;
    line-height: 1;
    font-size: 2rem;
  }
  .lightbox button:focus-visible {
    outline: 2px solid #fff;
    outline-offset: 2px;
  }
  .lightbox .close { top: 0.5rem; right: 0.5rem; font-size: 2.5rem; }
  .lightbox .nav { top: 50%; transform: translateY(-50%); }
  .lightbox .prev { left: 0.5rem; }
  .lightbox .next { right: 0.5rem; }
</style>
