---
import { SITE } from '~/lib/site';
const year = new Date().getUTCFullYear();
---

<footer class="site-footer">
  <div class="container">
    © {year} {SITE.author}
  </div>
</footer>

<style>
  .site-footer {
    margin-top: var(--sp-8);
    padding: var(--sp-5) 0;
    color: var(--muted);
    font-size: var(--fs-sm);
  }
</style>
