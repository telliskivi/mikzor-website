---
import { CATEGORIES, LABELS } from '~/lib/categories';
import { SITE } from '~/lib/site';

const path = Astro.url.pathname;

function isCurrent(href: string): boolean {
  if (href === '/') return path === '/' || path === '';
  return path === href || path.startsWith(href);
}
---

<header class="site-header">
  <div class="container">
    <a class="brand" href="/" aria-label={`${SITE.title} — home`}>
      <span class="given">Mikael</span> <span class="family">Ristmets</span>
    </a>
    <nav aria-label="primary">
      <ul>
        <li><a href="/" aria-current={isCurrent('/') ? 'page' : undefined}>Index</a></li>
        {CATEGORIES.map((c) => {
          const href = `/${c}/`;
          const { en } = LABELS[c];
          return (
            <li>
              <a href={href} aria-current={isCurrent(href) ? 'page' : undefined}>{en}</a>
            </li>
          );
        })}
        <li><a href="/about/" aria-current={isCurrent('/about/') ? 'page' : undefined}>About</a></li>
        <li><a href="/contact/" aria-current={isCurrent('/contact/') ? 'page' : undefined}>Contact</a></li>
      </ul>
    </nav>
  </div>
</header>

<style>
  .site-header {
    padding: var(--sp-7) 0 var(--sp-6);
  }
  .brand {
    display: block;
    text-decoration: none;
    color: var(--fg);
    font-family: var(--font-serif);
    font-size: var(--fs-md);
    letter-spacing: -0.005em;
    line-height: 1;
  }
  .brand .given {
    font-style: italic;
  }
  nav {
    margin-top: var(--sp-5);
  }
  nav ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-3) var(--sp-5);
    font-family: var(--font-sans);
    font-size: var(--fs-xs);
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }
  nav a {
    text-decoration: none;
    color: var(--muted);
  }
  nav a:hover,
  nav a:focus-visible,
  nav a[aria-current='page'] {
    color: var(--fg);
  }
</style>
