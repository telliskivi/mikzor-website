---
import { CATEGORIES, LABELS } from '~/lib/categories';
import { SITE } from '~/lib/site';

const path = Astro.url.pathname;

function isCurrent(href: string): boolean {
  if (href === '/') return path === '/' || path === '';
  return path === href || path.startsWith(href);
}
---

<header class="site-header">
  <div class="container row">
    <a class="brand" href="/">{SITE.title}</a>
    <nav aria-label="primary">
      <ul>
        {CATEGORIES.map((c) => {
          const href = `/${c}/`;
          const { en } = LABELS[c];
          return (
            <li>
              <a href={href} aria-current={isCurrent(href) ? 'page' : undefined}>{en}</a>
            </li>
          );
        })}
        <li><a href="/about/" aria-current={isCurrent('/about/') ? 'page' : undefined}>about</a></li>
        <li><a href="/contact/" aria-current={isCurrent('/contact/') ? 'page' : undefined}>contact</a></li>
      </ul>
    </nav>
  </div>
</header>

<style>
  .site-header {
    padding: var(--sp-5) 0 var(--sp-6);
  }
  .row {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--sp-3) var(--sp-5);
  }
  .brand {
    font-size: var(--fs-md);
    text-decoration: none;
    color: var(--fg);
  }
  nav ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-3) var(--sp-4);
    font-size: var(--fs-sm);
  }
  nav a {
    text-decoration: none;
    color: var(--muted);
  }
  nav a:hover,
  nav a:focus-visible,
  nav a[aria-current='page'] {
    color: var(--fg);
  }
</style>
