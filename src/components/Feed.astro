---
import FeedItem from './FeedItem.astro';
import type { Post } from '~/lib/posts';

interface Props {
  posts: Post[];
  emptyMessage?: string;
}

const { posts, emptyMessage = 'nothing here yet.' } = Astro.props;

// Newest at the top, but number chronologically (oldest = 1) so an
// archive number sticks to a post no matter where it appears.
const total = posts.length;
---

{posts.length === 0 ? (
  <p class="empty">{emptyMessage}</p>
) : (
  <div class="feed">
    {posts.map((post, i) => (
      <FeedItem post={post} index={total - i} />
    ))}
  </div>
)}

<style>
  .feed {
    border-top: 1px solid var(--rule);
  }
  .empty {
    color: var(--muted);
    font-style: italic;
    padding: var(--sp-6) 0;
  }
</style>
