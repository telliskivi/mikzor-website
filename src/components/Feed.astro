---
import FeedItem from './FeedItem.astro';
import type { Post } from '~/lib/posts';

interface Props {
  posts: Post[];
  emptyMessage?: string;
}

const { posts, emptyMessage = 'nothing here yet.' } = Astro.props;
---

{posts.length === 0 ? (
  <p class="empty">{emptyMessage}</p>
) : (
  <ul class="feed" role="list">
    {posts.map((post) => (
      <li><FeedItem post={post} /></li>
    ))}
  </ul>
)}

<style>
  .feed {
    list-style: none;
    padding: 0;
    margin: 0;
    border-top: 1px solid var(--rule);
  }
  .empty {
    color: var(--muted);
    padding: var(--sp-5) 0;
  }
</style>
