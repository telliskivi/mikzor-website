---
import BaseLayout from './BaseLayout.astro';
import { formatPostDate, toIsoDate } from '~/lib/date';
import type { Post } from '~/lib/posts';

interface Props {
  post: Post;
}

const { post } = Astro.props;
const { title, date, description, cover } = post.data;
const ogImage = cover ? cover.src : undefined;
---

<BaseLayout
  title={title}
  description={description}
  image={ogImage}
  type="article"
>
  <article class="container post">
    <header>
      <h1>{title}</h1>
      <time datetime={toIsoDate(date)} class="date">{formatPostDate(date)}</time>
    </header>
    <div class="prose">
      <slot />
    </div>
  </article>
</BaseLayout>

<style>
  .post header {
    margin-bottom: var(--sp-6);
  }
  .post h1 {
    font-size: var(--fs-lg);
    margin-bottom: var(--sp-2);
  }
  .date {
    color: var(--muted);
    font-size: var(--fs-sm);
  }
</style>
